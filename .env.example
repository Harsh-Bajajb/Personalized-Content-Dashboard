# API Keys for external services
# Replace these with your actual keys when running locally. Do NOT commit the real .env file.

# News API (e.g., newsapi.org)
NEXT_PUBLIC_NEWS_API_KEY=your_news_api_key_here

# Movie/Recommendations API (e.g., TMDB)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# Note: Currently, the application uses mocked RTK Query endpoints for demonstration
# purposes, so these keys are not strictly required to run the local dev server.
